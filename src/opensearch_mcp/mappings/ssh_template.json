{
  "index_patterns": ["case-*-ssh-*"],
  "template": {
    "mappings": {
      "properties": {
        "@timestamp": {"type": "date"},
        "source.ip": {"type": "ip", "ignore_malformed": true},
        "source.port": {"type": "integer"},
        "user.name": {"type": "keyword"},
        "ssh.auth_method": {"type": "keyword"},
        "ssh.event_type": {"type": "keyword"},
        "ssh.raw_line": {"type": "text"},
        "host.name": {"type": "keyword"},
        "vhir.source_file": {"type": "keyword"},
        "vhir.ingest_audit_id": {"type": "keyword"},
        "vhir.parse_method": {"type": "keyword"},
        "pipeline_version": {"type": "keyword"}
      }
    },
    "settings": {
      "default_pipeline": "vhir-geoip"
    }
  },
  "priority": 20
}
